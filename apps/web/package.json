{
  "name": "@ldgr/web",
  "version": "0.1.0",
  "private": true,
  "description": "ldgr web app — zero-knowledge bookkeeping in the browser",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build:wasm": "wasm-pack build ../../crates/ldgr-wasm --target web --release --out-dir ../../apps/web/pkg -- --no-default-features --features core,sync",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --experimental-strip-types --test test/integration.mjs test/sync-wasm.mjs test/admin-api.mjs"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.0",
    "@types/sql.js": "^1.4.11",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
