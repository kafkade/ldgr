# ─────────────────────────────────────────────────────────────────────────────
# ldgr-server configuration — copy to `.env` and edit:
#   cp .env.example .env
# All values below are safe defaults. Uncomment / change what you need.
# ─────────────────────────────────────────────────────────────────────────────

# ── Compose-only settings ────────────────────────────────────────────────────

# Image tag to pull from GHCR (e.g. v1.2.3, 1.2, 1, or latest). Pin an explicit
# version for production so upgrades are deliberate.
LDGR_VERSION=latest

# Host port to expose the server on (container always listens on 8080).
LDGR_HOST_PORT=8080

# ── Server settings (LDGR_*) ─────────────────────────────────────────────────

# Address the server binds inside the container. Must be 0.0.0.0 so the port is
# reachable from outside the container — do NOT use 127.0.0.1 here.
LDGR_BIND_ADDR=0.0.0.0:8080

# SQLite database path inside the container. Lives on the `ldgr-data` volume;
# there is normally no reason to change this.
LDGR_DB_PATH=/data/ldgr-server.db

# Who may create an account via the public register endpoint:
#   open         — anyone can self-register (typical for a personal instance)
#   invite-only  — requires an admin-issued invite token (default, most secure)
#   admin-only   — only an admin can create accounts
LDGR_REGISTRATION=invite-only

# First-run admin bootstrap. When set, the account that registers with this
# email becomes `admin` and bypasses the registration policy above — the
# recommended way to seed the first admin on an unattended deploy. Leave unset
# once your admin account exists.
#LDGR_ADMIN_EMAIL=you@example.com

# Session lifetime in hours (default 720 = 30 days).
LDGR_SESSION_TTL_HOURS=720

# Key-exchange relay offer TTL in minutes.
LDGR_RELAY_TTL_MINUTES=10

# Maximum encrypted blob size in bytes (default 52428800 = 50 MB).
LDGR_MAX_BLOB_BYTES=52428800

# Login (SRP-6a) handshake lifetime in seconds.
LDGR_SRP_HANDSHAKE_TTL_SECS=120

# Default per-user storage quota in bytes (default 1073741824 = 1 GiB).
LDGR_DEFAULT_QUOTA_BYTES=1073741824

# Cosmetic server name advertised by the discovery endpoint (never used for
# auth). Handy to label your instance.
LDGR_SERVER_NAME=ldgr-server

# ── Optional TLS reverse proxy (Caddy `tls` profile) ─────────────────────────
# Only needed if you run `docker compose --profile tls up -d`. Point your
# domain's DNS at this host first; Caddy will obtain a certificate automatically.

# Public domain that serves the API (e.g. ldgr.example.com).
#LDGR_DOMAIN=ldgr.example.com

# Email for Let's Encrypt/ACME expiry notices (optional but recommended).
#LDGR_ACME_EMAIL=you@example.com
